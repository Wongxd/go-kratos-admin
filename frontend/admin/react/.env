# 开发环境配置
# 可选值：dev, test, pre, prod
VITE_ENV=dev

# 是否启用 Mock 数据
VITE_MOCK=false

# 是否启用分析
VITE_ANALYZE=false

# 应用标题
VITE_APP_TITLE="GoWind Admin"

# 应用命名空间，用于缓存、store等功能的前缀，确保隔离
VITE_APP_NAMESPACE="gowind-admin"

# 应用版本 (用于 Sentry)
VITE_APP_VERSION="1.0.0"

# AES 加密密钥 (用于密码加密)
VITE_AES_KEY="f51d66a73d8a0927"
